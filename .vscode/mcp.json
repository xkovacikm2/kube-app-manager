{
    "servers": {
        "oraios/serena": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--context",
                "ide",
                "--project",
                "${workspaceFolder}"
            ]
        },
        "scida-library": {
            "command": "docker",
            "args": [
                "exec",
                "-i",
                "scida-mcp-server",
                "python",
                "-m",
                "mcp_server.cli",
                "stdio"
            ]
        }
    }
}